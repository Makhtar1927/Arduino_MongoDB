# =============================================================
# FICHIER .env.example — Projet IoT L3 CCAK
# Dupliquer ce fichier en ".env" et remplir les valeurs réelles
# NE JAMAIS COMMITTER le fichier .env sur GitHub
# =============================================================

# ── MongoDB Atlas ────────────────────────────────────────────
# Créer un cluster sur https://cloud.mongodb.com
# Format : mongodb+srv://<utilisateur>:<mot_de_passe>@<cluster>.mongodb.net/<base>
MONGO_URI=mongodb+srv://<utilisateur>:<mot_de_passe>@cluster0.xxxxx.mongodb.net/iot_database?appName=Cluster0

# ── Serveur Express ──────────────────────────────────────────
# Port local (Render.com utilise son propre PORT automatiquement)
PORT=5000

# ── Clé de sécurité API (doit correspondre à l'ESP32) ───────
# Doit être identique à : const char* apiKey dans le code Arduino
API_KEY=MonEsp32SecretKeyL3
